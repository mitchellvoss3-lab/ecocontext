# ===== LLM Provider Setup =====
# Precision-context supports multiple providers. Set credentials for ONE of them.
# Auto-detection: if you set an API key, that provider is used automatically.
# Force a provider: LLM_PROVIDER=anthropic|openai|gemini|ollama

# --- Anthropic (Claude Haiku + Sonnet) ---
# Get key at: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI (GPT-4o Mini + GPT-4o) ---
# Get key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1  # Optional, for custom deployment

# --- Google Gemini (Gemini 2.0 Flash Lite + Flash) ---
# Get key at: https://aistudio.google.com
# GEMINI_API_KEY=...

# --- Ollama (Local inference, free) ---
# Install from https://ollama.com, then run: ollama pull llama3.2:3b
# Default: http://localhost:11434
# OLLAMA_BASE_URL=http://localhost:11434

# ===== Server Settings =====
PORT=3000

# ===== Override Provider (optional) =====
# If set, this overrides auto-detection
# LLM_PROVIDER=anthropic

# Ollama (free, local — no key needed, just run `ollama serve`)
# OLLAMA_BASE_URL=http://localhost:11434

PORT=3000
